# ==========================================
# Bible Journey App Environment Configuration
# ==========================================

# --- Django Security and Debugging ---
# SECRET_KEY: A unique and unpredictable secret key used to secure signatures/sessions (Required)
SECRET_KEY=your-django-production-secret-key-change-me

# DEBUG: Turn debug mode on (True) or off (False). Keep False in production. (Optional, Default: False)
DEBUG=False

# ALLOWED_HOSTS: Comma-separated domain names or IP addresses that Django can serve (Required)
ALLOWED_HOSTS=apps.biblejourney.pro,localhost,127.0.0.1


# --- Database Configuration ---
# DB_ENGINE: DB backend to use. Options: 'sqlite' or 'postgresql'. (Optional, Default: sqlite)
DB_ENGINE=postgresql

# DB_NAME: Database name. (Required if engine is postgresql)
DB_NAME=postgres

# DB_USER: Database username. (Required if engine is postgresql)
DB_USER=postgres

# DB_PASSWORD: Database user password. (Required if engine is postgresql)
DB_PASSWORD=your_secure_postgres_db_password

# DB_HOST: Host address of the database. (Required if engine is postgresql)
DB_HOST=db

# DB_PORT: Port number of the database. (Optional, Default: 5432)
DB_PORT=5432


# --- Cache Configuration ---
# REDIS_URL: Redis URL used for Django caches and ASGI Channels backend. (Optional, Default: redis://127.0.0.1:6379/1)
REDIS_URL=redis://redis:6379/1


# --- Email Configuration (SMTP) ---
# EMAIL_HOST_USER: SMTP authentication username / sender email. (Required)
EMAIL_HOST_USER=your_email@gmail.com

# EMAIL_HOST_PASSWORD: SMTP authentication password / App password. (Required)
EMAIL_HOST_PASSWORD=your_secure_smtp_app_password


# --- Stripe Payment Configuration ---
# STRIPE_SECRET_KEY: Stripe API secret key. (Required)
STRIPE_SECRET_KEY=sk_test_51...

# STRIPE_PUBLISHABLE_KEY: Stripe API publishable key. (Required)
STRIPE_PUBLISHABLE_KEY=pk_test_51...

# STRIPE_WEBHOOK_SECRET: Stripe Webhook signing secret to verify authentic webhook requests. (Required)
STRIPE_WEBHOOK_SECRET=whsec_...

# STRIPE Pricing Identifiers (Price IDs from Stripe Dashboard)
STRIPE_WEEKLY_PRICE=price_1...
STRIPE_MONTHLY_PRICE=price_2...
STRIPE_YEARLY_PRICE=price_3...


# --- Docker Deployment Helpers ---
# RUN_MIGRATIONS: Automatically apply database migrations at container startup. (Optional, Default: false)
RUN_MIGRATIONS=true

# COLLECT_STATIC: Automatically compile static assets into STATIC_ROOT at container startup. (Optional, Default: false)
COLLECT_STATIC=true

# SERVICE_TYPE: Defines container process. Options: 'wsgi' (Django main web app), 'asgi' (WebSocket handlers), 'scheduler' (cron events). (Optional, Default: wsgi)
SERVICE_TYPE=wsgi
